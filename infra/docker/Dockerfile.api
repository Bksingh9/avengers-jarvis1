# syntax=docker/dockerfile:1.7
FROM python:3.11-slim AS builder

ENV PIP_NO_CACHE_DIR=1 PIP_DISABLE_PIP_VERSION_CHECK=1
WORKDIR /build

COPY pyproject.toml README.md ./
COPY src ./src
RUN pip install --upgrade pip wheel && pip install --prefix=/install ".[anthropic,bedrock,postgres,observability]"

FROM python:3.11-slim AS runtime

RUN useradd --uid 10001 --create-home avengers
USER 10001
WORKDIR /home/avengers/app

COPY --from=builder /install /usr/local
COPY --chown=10001:10001 src ./src
COPY --chown=10001:10001 config ./config
COPY --chown=10001:10001 prompts ./prompts
# JARVIS persona overlay (memory/<tenant>/persona.md) — without this the
# `jarvis` tenant runs in default voice instead of "Cap Brij" voice.
COPY --chown=10001:10001 memory ./memory

ENV PYTHONPATH=/home/avengers/app/src \
    AVENGERS_CONFIG_DIR=/home/avengers/app/config \
    AVENGERS_PROMPTS_DIR=/home/avengers/app/prompts \
    AVENGERS_ENVIRONMENT=prod

# Honour Render's $PORT env (Render injects PORT, we'd already bind to 8080
# everywhere else). Fly + docker-compose + local all use 8080 by default.
EXPOSE 8080
HEALTHCHECK --interval=30s --timeout=5s --start-period=30s --retries=3 \
  CMD python -c "import urllib.request, sys, os; \
    p=os.environ.get('PORT','8080'); \
    sys.exit(0 if urllib.request.urlopen(f'http://localhost:{p}/healthz', timeout=3).status==200 else 1)"

# Single worker — SSE pins one connection per worker for the duration of a
# brief stream. Scale horizontally on Fly/k8s instead of via workers.
# `--port ${PORT:-8080}` honours Render's PORT env without breaking Fly.
CMD ["sh", "-c", "uvicorn avengers.api.__main__:app --host 0.0.0.0 --port ${PORT:-8080}"]
