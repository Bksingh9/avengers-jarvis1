# Example backend env vars. Copy to .env locally — never commit a real .env.
# On Vercel: set these via Settings → Environment Variables.

# Comma-separated CORS allow-list. Wildcards via *.vercel.app supported.
AVENGERS_CORS_ORIGINS=https://*.vercel.app,http://localhost:3000

# Which commerce backend to register: fynd | jio | both
COMMERCE_BACKEND=both

# Shared secret for the Vercel Cron → /jarvis/proactive call.
# Generate with: openssl rand -hex 32
CRON_SECRET=replace-me

# Only needed for local dev with the Next.js dashboard pointing at a
# separately-hosted backend. In production-on-Vercel the top-level
# vercel.json rewrite handles /api/avengers/* — leave this unset.
# AVENGERS_API_INTERNAL=
